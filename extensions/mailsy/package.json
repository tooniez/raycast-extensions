{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "mailsy",
  "title": "Mailsy",
  "description": "Quickly Generate Disposable Email Address and view received mails.",
  "icon": "send.png",
  "author": "BalliAsghar",
  "platforms": [
    "macOS",
    "Windows"
  ],
  "categories": [
    "Communication",
    "Web"
  ],
  "keywords": [
    "mailsy",
    "mails",
    "email",
    "disposable",
    "disposable email",
    "temporary email",
    "temporary",
    "temp"
  ],
  "license": "MIT",
  "commands": [
    {
      "title": "Mailsy",
      "description": "View & Manage Mailsy",
      "name": "mailsy",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.10",
    "axios": "^1.13.6",
    "node-html-markdown": "^2.0.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "eslint": "^9.38.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "ray publish"
  }
}
