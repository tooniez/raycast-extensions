{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "isdown",
  "title": "IsDown",
  "description": "Search and check the status of services and cloud providers",
  "icon": "isdown.png",
  "author": "nunotomas",
  "contributors": ["Logan-8f"],
  "categories": [
    "Developer Tools"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "search",
      "title": "Search Service Status",
      "subtitle": "IsDown",
      "description": "Check current status for any service or cloud provider",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.7",
    "@raycast/utils": "^2.2.2"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "eslint": "^9.0.0",
    "prettier": "^3.0.3",
    "typescript": "^5.2.2"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  },
  "platforms": [
    "macOS",
    "Windows"
  ]
}
