{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "openrouter-manager",
  "title": "OpenRouter Manager",
  "description": "View your OpenRouter credits and manage your API keys",
  "icon": "extension-icon.png",
  "author": "ClaPalo",
  "platforms": [
    "macOS",
    "Windows"
  ],
  "categories": [
    "Developer Tools"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "show-credits",
      "title": "Show Credits",
      "description": "Show the credits usage",
      "mode": "view"
    },
    {
      "name": "show-api-keys",
      "title": "Show API Keys",
      "description": "Show the API keys",
      "mode": "view"
    },
    {
      "name": "create-api-key",
      "title": "Create API Key",
      "description": "Create a new API key",
      "mode": "view"
    },
    {
      "name": "update-api-key",
      "title": "Update API Key",
      "description": "Update an existing API key",
      "mode": "view",
      "arguments": [
        {
          "name": "hash",
          "type": "text",
          "placeholder": "API Key Hash",
          "required": true
        }
      ]
    }
  ],
  "preferences": [
    {
      "name": "management_key",
      "title": "Management Key",
      "description": "The management key to authenticate to the OpenRouter API",
      "type": "password",
      "required": true
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.8",
    "@raycast/utils": "^1.17.0",
    "date-fns": "^4.1.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.0.4",
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "prepublishOnly": "echo \"\\n\\nIt seems like you are trying to publish the Raycast extension to npm.\\n\\nIf you did intend to publish it to npm, remove the \\`prepublishOnly\\` script and rerun \\`npm publish\\` again.\\nIf you wanted to publish it to the Raycast Store instead, use \\`npm run publish\\` instead.\\n\\n\" && exit 1",
    "publish": "npx @raycast/api@latest publish"
  }
}
