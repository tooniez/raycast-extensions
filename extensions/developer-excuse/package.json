{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "developer-excuse",
  "title": "Developer Excuses",
  "description": "Insert a random developer excuse for not doing your work.",
  "icon": "excuse-icon.png",
  "author": "niemtec",
  "categories": [
    "Fun"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "index",
      "title": "Insert Developer Excuse",
      "description": "Inserts a randomly picked developer excuse into your current window",
      "mode": "no-view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  },
  "platforms": [
    "macOS"
  ]
}
