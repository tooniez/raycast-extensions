{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "inspire-search",
  "title": "Inspire HEP Search",
  "description": "Search papers on inspirehep.net and browse results inside Raycast. Includes actions to copy one or more bibtex entries, look up references or citations, and (when available) download pdf version.",
  "icon": "command-icon.png",
  "author": "rpenco",
  "categories": [
    "Web"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "index",
      "title": "Search Inspire HEP",
      "description": "Searches papers on inspirehep.net",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "sort",
      "title": "Default Order",
      "description": "Choose default ordering of search results",
      "required": false,
      "type": "dropdown",
      "data": [
        {
          "title": "Most Recent",
          "value": "mostrecent"
        },
        {
          "title": "Least Recent",
          "value": "leastrecent"
        },
        {
          "title": "Most Cited",
          "value": "mostcited"
        }
      ],
      "default": "mostrecent"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.15",
    "@raycast/utils": "^2.2.4",
    "node-fetch": "^3.3.2",
    "react-copy-to-clipboard": "^5.1.1"
  },
  "devDependencies": {
    "@raycast/eslint-config": "2.1.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  },
  "platforms": [
    "macOS",
    "Windows"
  ]
}
