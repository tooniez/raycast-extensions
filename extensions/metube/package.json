{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "metube",
  "title": "MeTube",
  "description": "Download videos from YouTube and other services through yt-dlp using MeTube.",
  "icon": "extension-icon.png",
  "author": "dot",
  "contributors": [
    "Zerebos"
  ],
  "categories": [
    "Media"
  ],
  "platforms": [
    "macOS",
    "Windows"
  ],
  "license": "MIT",
  "preferences": [
    {
      "name": "metubeUrl",
      "title": "MeTube Instance",
      "description": "URL (with port if necessary) to your MeTube instance",
      "type": "textfield",
      "default": "http://localhost:8081",
      "required": true
    },
    {
      "name": "quality",
      "title": "Quality",
      "description": "Preferred quality to download",
      "type": "dropdown",
      "required": false,
      "default": "best",
      "data": [
        {
          "title": "Best",
          "value": "best"
        },
        {
          "title": "1440p",
          "value": "1440"
        },
        {
          "title": "1080p",
          "value": "1080"
        },
        {
          "title": "720p",
          "value": "720"
        },
        {
          "title": "480p",
          "value": "480"
        }
      ]
    },
    {
      "name": "format",
      "title": "Format",
      "description": "Preferred format to download",
      "type": "dropdown",
      "required": false,
      "default": "any",
      "data": [
        {
          "title": "Any",
          "value": "any"
        },
        {
          "title": "MP4",
          "value": "mp4"
        },
        {
          "title": "M4A",
          "value": "m4a"
        },
        {
          "title": "MP3",
          "value": "mp3"
        },
        {
          "title": "OPUS",
          "value": "opus"
        },
        {
          "title": "WAV",
          "value": "wav"
        },
        {
          "title": "FLAC",
          "value": "flac"
        },
        {
          "title": "Thumbnail",
          "value": "thumbnail"
        }
      ]
    }
  ],
  "commands": [
    {
      "name": "clipboard-to-metube",
      "title": "Clipboard to MeTube",
      "description": "Sends content of clipboard to MeTube",
      "mode": "no-view"
    },
    {
      "mode": "view",
      "name": "add-to-metube",
      "description": "Add url to MeTube through a form",
      "title": "Add to MeTube"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.19",
    "@raycast/utils": "^2.2.5"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "25.9.1",
    "@types/react": "19.2.16",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "prepublishOnly": "echo \"\\n\\nIt seems like you are trying to publish the Raycast extension to npm.\\n\\nIf you did intend to publish it to npm, remove the \\`prepublishOnly\\` script and rerun \\`npm publish\\` again.\\nIf you wanted to publish it to the Raycast Store instead, use \\`npm run publish\\` instead.\\n\\n\" && exit 1",
    "publish": "npx @raycast/api@latest publish"
  }
}
