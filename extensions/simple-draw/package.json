{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "simple-draw",
  "title": "Simple Draw",
  "description": "Annotate clipboard images with drawing tools",
  "icon": "command-icon.png",
  "author": "duduzeta",
  "categories": [
    "Design Tools"
  ],
  "license": "MIT",
  "platforms": [
    "macOS"
  ],
  "commands": [
    {
      "name": "simple-draw",
      "title": "Simple Draw",
      "description": "Open clipboard image in a drawing canvas",
      "mode": "no-view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.93.3",
    "@raycast/utils": "^1.19.1"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "22.13.4",
    "eslint": "^10.4.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "prepublishOnly": "echo \"Error: no publish\" && exit 1",
    "publish": "npx @raycast/api@latest publish"
  }
}
