  {
    "title": "DATE_TRUNC",
    "type": "function",
    "summary": "Truncate timestamps to a given precision (day, month, etc.).",
    "syntax": {
      "common": ["DATE_TRUNC(unit, timestamp_expr)"],
      "overrides": {
        "mysql": ["DATE_FORMAT(timestamp_expr, format) /* emulate */"],
        "sqlite": ["strftime(format, timestamp_expr) /* emulate */"],
        "tsql": ["DATETRUNC(unit, timestamp_expr)"]
      }
    },
    "examples": {
      "postgres": ["SELECT DATE_TRUNC('day', created_at) FROM events;"],
      "mysql": ["SELECT DATE_FORMAT(created_at, '%Y-%m-%d 00:00:00') FROM events;"],
      "sqlite": ["SELECT strftime('%Y-%m-%d 00:00:00', created_at) FROM events;"],
      "tsql": ["SELECT DATETRUNC(day, created_at) FROM events;"]
    },
    "notes": ["Available function names and units differ by dialect."],
    "aliases": ["datetrunc"],
    "tags": ["date", "time", "comparison matrix"],
    "related": ["CURRENT_TIMESTAMP", "EXTRACT"],
    "dialects": {
      "supported": ["postgres", "mysql", "sqlite", "tsql"],
      "notes": {
        "mysql": "No direct DATE_TRUNC; use formatting/expression alternatives.",
        "tsql": "Use DATETRUNC in supported SQL Server versions."
      }
    },
    "parameters": ["unit: truncation grain", "timestamp_expr: value to truncate"]
  },
