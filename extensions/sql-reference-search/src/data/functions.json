  {
    "title": "JSON_EXTRACT",
    "type": "function",
    "summary": "Extract JSON value at a path.",
    "syntax": {
      "common": ["JSON_EXTRACT(json_doc, path)"],
      "overrides": {
        "postgres": ["json_doc -> path", "json_doc ->> path"],
        "tsql": ["JSON_VALUE(json_doc, path)"]
      }
    },
    "examples": {
      "mysql": ["SELECT JSON_EXTRACT(payload, '$.status') FROM events;"],
      "sqlite": ["SELECT json_extract(payload, '$.status') FROM events;"],
      "postgres": ["SELECT payload->>'status' FROM events;"],
      "tsql": ["SELECT JSON_VALUE(payload, '$.status') FROM events;"]
    },
    "notes": ["Extraction returns JSON or text depending on operator/function."],
    "aliases": ["json path"],
