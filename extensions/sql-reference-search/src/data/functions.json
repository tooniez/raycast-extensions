  {
    "title": "STRING_AGG",
    "type": "function",
    "summary": "Concatenate grouped string values using a separator.",
    "syntax": {
      "common": ["STRING_AGG(expression, separator)"],
      "overrides": {
        "mysql": ["GROUP_CONCAT(expression SEPARATOR separator)"],
        "sqlite": ["GROUP_CONCAT(expression, separator)"],
        "tsql": ["STRING_AGG(expression, separator)"]
      }
    },
    "examples": {
      "postgres": ["SELECT department, STRING_AGG(name, ', ') FROM employees GROUP BY department;"],
      "mysql": ["SELECT department, GROUP_CONCAT(name SEPARATOR ', ') FROM employees GROUP BY department;"],
      "sqlite": ["SELECT department, GROUP_CONCAT(name, ', ') FROM employees GROUP BY department;"],
      "tsql": ["SELECT department, STRING_AGG(name, ', ') FROM employees GROUP BY department;"]
    },
    "notes": ["Function name differs by dialect."],
    "aliases": ["group_concat", "listagg"],
    "tags": ["aggregation", "comparison matrix"],
    "related": ["CONCAT", "GROUP BY"],
    "dialects": {
      "supported": ["postgres", "mysql", "sqlite", "tsql"],
      "notes": {
        "mysql": "Use GROUP_CONCAT instead of STRING_AGG."
      }
    },
    "parameters": ["expression: text to concatenate", "separator: delimiter between values"]
  },
