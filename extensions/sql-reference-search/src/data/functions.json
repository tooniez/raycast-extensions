  {
    "title": "DATEADD / INTERVAL",
    "type": "function",
    "summary": "Add or subtract time units from temporal values.",
    "syntax": {
      "common": ["timestamp_expr + INTERVAL 'n unit'"],
      "overrides": {
        "mysql": ["DATE_ADD(timestamp_expr, INTERVAL n unit)"],
        "sqlite": ["datetime(timestamp_expr, '+n unit')"],
        "tsql": ["DATEADD(unit, n, timestamp_expr)"]
      }
    },
    "examples": {
      "postgres": ["SELECT created_at + INTERVAL '7 days' FROM events;"],
      "mysql": ["SELECT DATE_ADD(created_at, INTERVAL 7 DAY) FROM events;"],
      "sqlite": ["SELECT datetime(created_at, '+7 day') FROM events;"],
      "tsql": ["SELECT DATEADD(day, 7, created_at) FROM events;"]
    },
    "notes": ["Date arithmetic syntax varies heavily by engine."],
    "aliases": ["dateadd", "interval"],
    "tags": ["date", "time", "dialect difference"],
    "related": ["DATE_TRUNC", "EXTRACT"],
    "dialects": { "supported": ["postgres", "mysql", "sqlite", "tsql"] },
    "parameters": ["unit: date part", "n: amount", "timestamp_expr: source value"]
  },
