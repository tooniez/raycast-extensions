  },
  {
    "title": "JSON_VALUE",
    "type": "function",
    "summary": "Extract scalar text value from JSON at a path.",
    "syntax": {
      "common": ["JSON_VALUE(json_doc, path)"],
      "overrides": {
        "postgres": ["json_doc ->> path"],
        "mysql": ["JSON_UNQUOTE(JSON_EXTRACT(json_doc, path))"],
        "sqlite": ["json_extract(json_doc, path)"]
      }
    },
    "examples": {
      "tsql": ["SELECT JSON_VALUE(payload, '$.status') FROM events;"],
      "postgres": ["SELECT payload->>'status' FROM events;"],
      "mysql": ["SELECT JSON_UNQUOTE(JSON_EXTRACT(payload, '$.status')) FROM events;"],
      "sqlite": ["SELECT json_extract(payload, '$.status') FROM events;"]
    },
    "notes": ["T-SQL provides JSON_VALUE natively for scalar extraction."],
    "aliases": ["json scalar"],
    "tags": ["json", "dialect difference"],
    "related": ["JSON_EXTRACT", "JSON Operators"],
