{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "shadcn-ui",
  "title": "shadcn/ui",
  "description": "Browse shadcn/ui documentation, components and examples",
  "icon": "extension-icon.png",
  "author": "luisFilipePT",
  "contributors": [
    "williamwelsh",
    "Olivier-OG",
    "ridemountainpig",
    "siddharth-2382",
    "1weiho"
  ],
  "categories": [
    "Documentation",
    "Developer Tools"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "search-documentation",
      "title": "Search Documentation",
      "subtitle": "shadcn/ui",
      "description": "Search shadcn/ui documentation and open it in the browser",
      "keywords": [
        "css",
        "ui",
        "documentation"
      ],
      "mode": "view"
    },
    {
      "name": "search-components",
      "title": "Search Components",
      "subtitle": "shadcn/ui",
      "keywords": [
        "css",
        "ui",
        "components"
      ],
      "description": "Search shadcn/ui components",
      "mode": "view"
    },
    {
      "name": "search-examples",
      "title": "Search Examples",
      "subtitle": "shadcn/ui",
      "description": "Search shadcn/ui examples",
      "mode": "view"
    },
    {
      "name": "search-registries",
      "title": "Search Registries",
      "subtitle": "shadcn/ui",
      "description": "Search shadcn/ui registries",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "@octokit/types": "^16.0.0",
    "@raycast/api": "^1.104.8",
    "@raycast/utils": "^2.2.2",
    "js-yaml": "^4.1.1",
    "node-fetch": "^3.3.2",
    "octokit": "^5.0.5"
  },
  "devDependencies": {
    "@raycast/eslint-config": "2.1.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "25.3.3",
    "@types/react": "19.2.14",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  },
  "platforms": [
    "macOS",
    "Windows"
  ]
}
