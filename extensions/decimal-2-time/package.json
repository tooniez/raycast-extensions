{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "decimal-2-time",
  "title": "Decimal 2 Time",
  "description": "Converts between decimal time and HH:MM:SS format",
  "icon": "command-icon.png",
  "author": "rhuk",
  "categories": [
    "Developer Tools"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "dectime",
      "title": "Decimal 2 Time",
      "description": "Convert between decimal and time formats",
      "mode": "view",
      "arguments": [
        {
          "name": "value",
          "placeholder": "3.4322 or 01:30:00",
          "type": "text",
          "required": true
        }
      ],
      "preferences": [
        {
          "name": "autoCopy",
          "type": "checkbox",
          "title": "Auto Copy",
          "description": "Instantly copy the result to clipboard instead of showing a list",
          "required": false,
          "default": false,
          "label": "Copy result to clipboard automatically"
        }
      ]
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.12"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.0.4",
    "@types/node": "22.13.10",
    "@types/react": "19.0.12",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "prepublishOnly": "echo \"Error: no publish\" && exit 1",
    "publish": "npx @raycast/api@latest publish"
  },
  "platforms": [
    "macOS"
  ]
}
