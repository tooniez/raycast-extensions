{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "leetcode",
  "title": "LeetCode",
  "description": "Search LeetCode problem, view LeetCode daily challenge, view LeetCode problem and more.",
  "icon": "leetcode.png",
  "author": "justin0u0",
  "contributors": [
    "xmok",
    "doxxx93",
    "svenhofman"
  ],
  "categories": [
    "Web"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "daily-challenge",
      "title": "View LeetCode Daily Challenge",
      "subtitle": "LeetCode",
      "description": "View the today daily-challenge problem.",
      "mode": "view"
    },
    {
      "name": "problem-search",
      "title": "Search LeetCode Problems",
      "subtitle": "LeetCode",
      "description": "Search and preview the LeetCode problems.",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.19",
    "@raycast/utils": "^2.2.5",
    "node-html-markdown": "^2.0.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/turndown": "^5.0.6",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "ray publish"
  },
  "preferences": [
    {
      "name": "defaultLanguage",
      "title": "Default Programming Language",
      "description": "Select your preferred programming language",
      "type": "dropdown",
      "required": false,
      "default": "python",
      "data": [
        {
          "title": "Python",
          "value": "python"
        },
        {
          "title": "JavaScript",
          "value": "javascript"
        },
        {
          "title": "TypeScript",
          "value": "typescript"
        },
        {
          "title": "Java",
          "value": "java"
        },
        {
          "title": "C++",
          "value": "cpp"
        },
        {
          "title": "C",
          "value": "c"
        },
        {
          "title": "C#",
          "value": "csharp"
        },
        {
          "title": "Ruby",
          "value": "ruby"
        },
        {
          "title": "Swift",
          "value": "swift"
        },
        {
          "title": "Kotlin",
          "value": "kotlin"
        },
        {
          "title": "Go",
          "value": "go"
        }
      ]
    },
    {
      "name": "showProblemStats",
      "title": "Problem Stats",
      "label": "Show difficulty, likes, dislikes, and acceptance rate",
      "description": "If enabled, the problem's difficulty, likes, dislikes, and acceptance stats are shown above and below the problem description.",
      "type": "checkbox",
      "required": false,
      "default": true
    }
  ],
  "platforms": [
    "macOS",
    "Windows"
  ]
}
