{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "asafamos-accessibility-scanner",
  "title": "AsafAmos — Accessibility Scanner",
  "description": "Scan any URL for WCAG 2.1 / 2.2 AA accessibility violations and browse axe-core results in Raycast.",
  "icon": "command-icon.png",
  "author": "asafamos",
  "categories": [
    "Developer Tools",
    "Web"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "scan",
      "title": "Scan URL for Accessibility",
      "description": "Run an axe-core scan against any public URL and show violations.",
      "mode": "view",
      "arguments": [
        {
          "name": "url",
          "type": "text",
          "placeholder": "https://example.com",
          "required": true
        }
      ]
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.19"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  },
  "platforms": [
    "macOS",
    "Windows"
  ]
}
