{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "superwhisper",
  "title": "Superwhisper - Offline Voice to Text",
  "description": "Start a recording, change Modes and open settings. Requires installing superwhisper.",
  "icon": "superwhisper-light-icon.png",
  "author": "nchudleigh",
  "contributors": [
    "stelo",
    "nagauta",
    "Aayush9029"
  ],
  "categories": [
    "Productivity"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "toggle-record",
      "title": "Start Recording",
      "subtitle": "superwhisper",
      "description": "Start Recording",
      "mode": "no-view",
      "icon": "superwhisper-light-icon.png"
    },
    {
      "name": "search-history",
      "title": "Search History",
      "subtitle": "superwhisper",
      "description": "Search through your recording history",
      "mode": "view",
      "icon": "superwhisper-light-icon.png",
      "preferences": [
        {
          "name": "recordingDir",
          "title": "Recording Directory",
          "description": "Directory configured to store recording files",
          "type": "directory",
          "required": false,
          "default": "~/Documents/superwhisper/recordings"
        }
      ]
    },
    {
      "name": "copy-last-history",
      "title": "Copy Last History",
      "subtitle": "superwhisper",
      "description": "Copy the most recent Superwhisper transcript to clipboard",
      "mode": "no-view",
      "icon": "superwhisper-light-icon.png",
      "preferences": [
        {
          "name": "transcriptVariant",
          "title": "Transcript Variant",
          "description": "Transcript variant to copy",
          "type": "dropdown",
          "required": true,
          "default": "processed",
          "data": [
            {
              "title": "AI Processed",
              "value": "processed"
            },
            {
              "title": "Unprocessed",
              "value": "unprocessed"
            }
          ]
        }
      ]
    },
    {
      "name": "paste-last-history",
      "title": "Paste Last History",
      "subtitle": "superwhisper",
      "description": "Paste the most recent Superwhisper transcript into the active app",
      "mode": "no-view",
      "icon": "superwhisper-light-icon.png",
      "preferences": [
        {
          "name": "transcriptVariant",
          "title": "Transcript Variant",
          "description": "Transcript variant to paste",
          "type": "dropdown",
          "required": true,
          "default": "processed",
          "data": [
            {
              "title": "AI Processed",
              "value": "processed"
            },
            {
              "title": "Unprocessed",
              "value": "unprocessed"
            }
          ]
        }
      ]
    },
    {
      "name": "select-mode",
      "title": "Select Mode",
      "subtitle": "superwhisper",
      "description": "Change the mode you are using",
      "mode": "view",
      "icon": "superwhisper-light-icon.png",
      "preferences": [
        {
          "name": "modeDir",
          "title": "Mode Directory",
          "description": "Directory configured to store mode files",
          "type": "directory",
          "required": false,
          "default": "~/Documents/superwhisper/modes"
        }
      ]
    },
    {
      "name": "open-settings",
      "title": "Open Settings",
      "subtitle": "superwhisper",
      "description": "Open the superwhisper settings page",
      "mode": "no-view",
      "icon": "superwhisper-light-icon.png"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.103.0",
    "@raycast/utils": "^1.16.1",
    "date-fns": "^4.1.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.6",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "eslint": "^8.51.0",
    "prettier": "^3.1.1",
    "typescript": "^5.2.2"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@raycast"
    ]
  },
  "platforms": [
    "macOS"
  ]
}
