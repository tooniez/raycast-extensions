{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "tinypng",
  "title": "TinyPNG",
  "description": "Compress the selected images in Finder with TinyPNG.",
  "icon": "tinypng-icon.png",
  "author": "kawamataryo",
  "contributors": [
    "j3lte",
    "thuggyduck"
  ],
  "categories": [
    "Developer Tools"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "compressImages",
      "title": "Compress Images",
      "subtitle": "TinyPNG",
      "description": "Compress selected images with TinyPNG.",
      "mode": "no-view"
    },
    {
      "name": "compressImagesMultipleTimes",
      "title": "Compress Images Multiple Times",
      "subtitle": "TinyPNG",
      "description": "Compress selected images with TinyPNG multiple times.",
      "mode": "no-view",
      "arguments": [
        {
          "name": "count",
          "placeholder": "2 times",
          "type": "dropdown",
          "description": "Number of compression passes",
          "required": false,
          "data": [
            {
              "value": "2 times",
              "title": "2 times"
            },
            {
              "value": "3 times",
              "title": "3 times"
            },
            {
              "value": "4 times",
              "title": "4 times"
            },
            {
              "value": "5 times",
              "title": "5 times"
            }
          ]
        }
      ]
    },
    {
      "name": "resizingImages",
      "title": "Resizing Images",
      "subtitle": "TinyPNG",
      "description": "Compress and resizing selected images with TinyPNG.",
      "mode": "no-view",
      "arguments": [
        {
          "name": "method",
          "placeholder": "fit",
          "type": "dropdown",
          "description": "Resize method",
          "required": true,
          "data": [
            {
              "value": "fit",
              "title": "fit"
            },
            {
              "value": "scale",
              "title": "scale"
            },
            {
              "value": "cover",
              "title": "cover"
            },
            {
              "value": "thumb",
              "title": "thumb"
            }
          ]
        },
        {
          "name": "width",
          "placeholder": "width(px)",
          "type": "text",
          "description": "Width to be resized",
          "required": false
        },
        {
          "name": "height",
          "placeholder": "height(px)",
          "type": "text",
          "description": "height to be resized",
          "required": false
        }
      ]
    }
  ],
  "preferences": [
    {
      "title": "API Key",
      "name": "apiKey",
      "description": "TinyPNG API Key.",
      "type": "password",
      "required": true
    },
    {
      "title": "Destination Folder Path",
      "name": "destinationFolderPath",
      "description": "Set Destination Folder path. Specify an absolute path or a relative path from the target file.",
      "type": "textfield",
      "required": true,
      "default": "./compressed-images"
    },
    {
      "title": "Options",
      "name": "overwrite",
      "description": "Whether to overwrite the original image file.",
      "type": "checkbox",
      "label": "Overwrite Original Image File",
      "default": false,
      "required": false
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.20",
    "node-fetch": "^3.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.2.0",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "eslint": "^10.6.0",
    "prettier": "^3.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "prepublishOnly": "echo \"\\n\\nIt seems like you are trying to publish the Raycast extension to npm.\\n\\nIf you did intend to publish it to npm, remove the \\`prepublishOnly\\` script and rerun \\`npm publish\\` again.\\nIf you wanted to publish it to the Raycast Store instead, use \\`npm run publish\\` instead.\\n\\n\" && exit 1",
    "publish": "npx -y @raycast/api@latest publish",
    "test": "vitest"
  },
  "platforms": [
    "macOS"
  ]
}
