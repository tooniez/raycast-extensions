{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "bundles",
  "title": "Bundles",
  "description": "Organize applications, websites, and nested collections in custom bundles",
  "icon": "icon.png",
  "author": "Jace",
  "categories": [
    "Productivity",
    "System"
  ],
  "license": "MIT",
  "preferences": [
    {
      "name": "folderContentsSortPrimary",
      "type": "dropdown",
      "required": true,
      "title": "🥇 Primary Sort",
      "description": "Primary sort method for items inside bundles",
      "default": "alphabetical-asc",
      "data": [
        {
          "title": "A → Z",
          "value": "alphabetical-asc"
        },
        {
          "title": "Z → A",
          "value": "alphabetical-desc"
        },
        {
          "title": "Short → Long",
          "value": "length-asc"
        },
        {
          "title": "Long → Short",
          "value": "length-desc"
        },
        {
          "title": "Old → New",
          "value": "recent-asc"
        },
        {
          "title": "New → Old",
          "value": "recent-desc"
        },
        {
          "title": "None",
          "value": "none"
        }
      ]
    },
    {
      "name": "folderContentsSortSecondary",
      "type": "dropdown",
      "required": true,
      "title": "🥈 Secondary Sort",
      "description": "Used when items are equal by the first sort",
      "default": "none",
      "data": [
        {
          "title": "A → Z",
          "value": "alphabetical-asc"
        },
        {
          "title": "Z → A",
          "value": "alphabetical-desc"
        },
        {
          "title": "Short → Long",
          "value": "length-asc"
        },
        {
          "title": "Long → Short",
          "value": "length-desc"
        },
        {
          "title": "Old → New",
          "value": "recent-asc"
        },
        {
          "title": "New → Old",
          "value": "recent-desc"
        },
        {
          "title": "None",
          "value": "none"
        }
      ]
    },
    {
      "name": "folderContentsSortTertiary",
      "type": "dropdown",
      "required": true,
      "title": "🥉 Tertiary Sort",
      "description": "Used when items are equal by the first two sorts",
      "default": "none",
      "data": [
        {
          "title": "A → Z",
          "value": "alphabetical-asc"
        },
        {
          "title": "Z → A",
          "value": "alphabetical-desc"
        },
        {
          "title": "Short → Long",
          "value": "length-asc"
        },
        {
          "title": "Long → Short",
          "value": "length-desc"
        },
        {
          "title": "Old → New",
          "value": "recent-asc"
        },
        {
          "title": "New → Old",
          "value": "recent-desc"
        },
        {
          "title": "None",
          "value": "none"
        }
      ]
    },
    {
      "name": "folderContentsViewType",
      "type": "dropdown",
      "required": true,
      "title": "📋 View Type",
      "description": "How to display items when viewing bundle contents",
      "default": "list",
      "data": [
        {
          "title": "List View",
          "value": "list"
        },
        {
          "title": "Grid View",
          "value": "grid"
        }
      ]
    },
    {
      "name": "showPreviewPane",
      "type": "checkbox",
      "required": true,
      "title": "Preview Pane",
      "description": "Show bundle contents in a preview pane beside the bundle list",
      "label": "Show Preview Pane",
      "default": false
    },
    {
      "name": "gridSeparateSections",
      "type": "checkbox",
      "required": true,
      "title": "Bundle Contents",
      "description": "Group apps, websites, and bundles into separate sections",
      "label": "Separate Apps, Websites & Bundles",
      "default": true
    },
    {
      "name": "defaultFolderColor",
      "type": "textfield",
      "required": false,
      "title": "Default Bundle Color",
      "description": "CSS color name or hex code for new bundles",
      "placeholder": "coral"
    }
  ],
  "commands": [
    {
      "name": "index",
      "title": "Bundles",
      "description": "Search and open your custom bundles",
      "mode": "view",
      "keywords": [
        "bundle",
        "bundles",
        "organize"
      ]
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.6",
    "@raycast/utils": "^2.2.2"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "eslint": "^9.39.2",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  },
  "platforms": [
    "macOS"
  ]
}
