{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "ultrahuman-insights",
  "title": "Ultrahuman Insights",
  "description": "Smart insights, AI tools, and trend charts for your Ultrahuman Ring AIR.",
  "icon": "extension-icon.png",
  "author": "aryan_rustagi",
  "contributors": [
    "0xdhrv"
  ],
  "categories": [
    "Data",
    "Productivity"
  ],
  "keywords": [
    "ultrahuman",
    "health",
    "sleep",
    "hrv",
    "heart-rate",
    "recovery",
    "ring-air",
    "wearable",
    "biometrics",
    "quantified-self"
  ],
  "license": "MIT",
  "preferences": [
    {
      "name": "apiToken",
      "title": "API Token",
      "description": "Your Ultrahuman Partner API token (from partner.ultrahuman.com)",
      "type": "password",
      "required": true
    }
  ],
  "commands": [
    {
      "name": "menu-bar",
      "title": "Menu Bar Sleep Score",
      "description": "Show last night's Ultrahuman sleep score in the macOS menu bar, color-coded by status.",
      "mode": "menu-bar",
      "interval": "5m",
      "platforms": [
        "macOS"
      ]
    },
    {
      "name": "today",
      "title": "Today's Health",
      "description": "View every available Ultrahuman metric for today with smart insights and 7-day deltas.",
      "mode": "view"
    },
    {
      "name": "sleep",
      "title": "Sleep Detail",
      "description": "Last night's sleep score, stages, vitals, and quality breakdown.",
      "mode": "view"
    },
    {
      "name": "hrv",
      "title": "HRV & Heart Rate",
      "description": "Today's HRV and resting heart rate with 7-day trend charts.",
      "mode": "view"
    },
    {
      "name": "recovery",
      "title": "Recovery & Movement",
      "description": "Recovery, Movement, and Sleep indices with daily trends and personalised insights.",
      "mode": "view"
    },
    {
      "name": "trends",
      "title": "7-Day Trends",
      "description": "Per-day history for every Ultrahuman metric over the last 7 days.",
      "mode": "view"
    }
  ],
  "tools": [
    {
      "name": "get-today",
      "title": "Get Today's Metrics",
      "description": "Get a snapshot of all of today's Ultrahuman metrics, including sleep, HRV, recovery, and movement."
    },
    {
      "name": "get-metric",
      "title": "Get One Metric",
      "description": "Get a single Ultrahuman metric for a specific date."
    },
    {
      "name": "get-trend",
      "title": "Get Metric Trend",
      "description": "Get N days of history (1–7) for a single Ultrahuman metric."
    }
  ],
  "ai": {
    "evals": [
      {
        "input": "@ultrahuman-insights how did I sleep last night",
        "mocks": {
          "get-today": {
            "date": "2026-06-18",
            "as_of": "2026-06-18T08:00:00.000Z",
            "stale": false,
            "available": true,
            "metrics": {
              "date": "2026-06-18",
              "sleep_score": 82,
              "total_sleep": 420,
              "hrv": 68,
              "recovery_index": 79
            }
          }
        },
        "expected": [
          {
            "callsTool": {
              "name": "get-today",
              "arguments": {}
            }
          }
        ],
        "usedAsExample": true
      },
      {
        "input": "@ultrahuman-insights what was my HRV today",
        "mocks": {
          "get-metric": {
            "date": "2026-06-18",
            "as_of": "2026-06-18T08:00:00.000Z",
            "stale": false,
            "metric": "hrv",
            "label": "HRV",
            "value": 68,
            "formatted_value": "68 ms",
            "available": true
          }
        },
        "expected": [
          {
            "callsTool": {
              "name": "get-metric",
              "arguments": {
                "metric": "hrv"
              }
            }
          }
        ]
      },
      {
        "input": "@ultrahuman-insights is my HRV trending down this week",
        "mocks": {
          "get-trend": {
            "date": "2026-06-18",
            "as_of": "2026-06-18T08:00:00.000Z",
            "stale": false,
            "metric": "hrv",
            "label": "HRV",
            "days": 7,
            "series": [
              {
                "date": "2026-06-12",
                "value": 72,
                "formatted_value": "72 ms"
              },
              {
                "date": "2026-06-13",
                "value": 70,
                "formatted_value": "70 ms"
              },
              {
                "date": "2026-06-14",
                "value": 69,
                "formatted_value": "69 ms"
              },
              {
                "date": "2026-06-15",
                "value": 67,
                "formatted_value": "67 ms"
              },
              {
                "date": "2026-06-16",
                "value": 66,
                "formatted_value": "66 ms"
              },
              {
                "date": "2026-06-17",
                "value": 65,
                "formatted_value": "65 ms"
              },
              {
                "date": "2026-06-18",
                "value": 64,
                "formatted_value": "64 ms"
              }
            ]
          }
        },
        "expected": [
          {
            "callsTool": {
              "name": "get-trend",
              "arguments": {
                "metric": "hrv"
              }
            }
          }
        ]
      }
    ]
  },
  "dependencies": {
    "@raycast/api": "^1.104.19"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "^25.9.3",
    "@types/react": "19.2.17",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  },
  "platforms": [
    "macOS",
    "Windows"
  ]
}
