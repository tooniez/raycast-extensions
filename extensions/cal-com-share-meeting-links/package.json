{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "cal-com-share-meeting-links",
  "title": "Cal.com",
  "description": "Manage your Cal.com schedules, bookings, out-of-office, and meeting links from Raycast",
  "icon": "logo.png",
  "author": "eluce2",
  "owner": "cal",
  "access": "public",
  "license": "MIT",
  "categories": [
    "Communication",
    "Productivity"
  ],
  "contributors": [
    "peduarte",
    "pernielsentikaer",
    "alexs",
    "stelo",
    "runofthemilgeek",
    "andrewbenson"
  ],
  "commands": [
    {
      "name": "index",
      "title": "Share Meeting Link",
      "subtitle": "Cal.com",
      "description": "Copy Meeting URL",
      "mode": "view"
    },
    {
      "name": "view-bookings",
      "title": "View Bookings",
      "subtitle": "Cal.com",
      "description": "View your upcoming Cal.com bookings",
      "mode": "view"
    },
    {
      "name": "view-availability",
      "title": "View Availability",
      "subtitle": "Cal.com",
      "description": "View and manage your Cal.com availability schedules",
      "mode": "view"
    },
    {
      "name": "out-of-office",
      "title": "Out of Office",
      "subtitle": "Cal.com",
      "description": "View and manage your Cal.com out-of-office entries",
      "mode": "view"
    },
    {
      "name": "create-out-of-office",
      "title": "Create Out of Office",
      "subtitle": "Cal.com",
      "description": "Schedule a new out-of-office entry (with draft support)",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "token",
      "type": "password",
      "required": true,
      "title": "API Key",
      "description": "Cal.com API Key",
      "link": "https://app.cal.com/settings/developer",
      "placeholder": "Cal.com API Key"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.12",
    "@raycast/utils": "^2.2.3",
    "axios": "^1.8.4",
    "dayjs": "^1.11.11",
    "moment": "^2.30.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/react": "^19.0.10",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.14.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.2",
    "typescript": "^5.5.2"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  },
  "platforms": [
    "macOS"
  ]
}
