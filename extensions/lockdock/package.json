{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "lockdock",
  "title": "Lockdock",
  "description": "Lock the macOS Dock to a specific display",
  "icon": "extension-icon.png",
  "author": "mishamyrt",
  "platforms": [
    "macOS"
  ],
  "categories": [
    "System"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "pin",
      "title": "Pin Dock",
      "description": "Pin Dock to specific display",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.16",
    "@raycast/utils": "^1.17.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "eslint": "^9.22.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0"
  },
  "scripts": {
    "build": "ray build -e dist -o dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
