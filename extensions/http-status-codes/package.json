{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "http-status-codes",
  "title": "HTTP Status Codes",
  "description": "Quickly look up HTTP status codes",
  "icon": "command-icon.png",
  "author": "Alex_",
  "platforms": [
    "macOS",
    "Windows"
  ],
  "contributors": [
    "PKlempe"
  ],
  "pastContributors": [
    "pernielsentikaer",
    "lucasmezencio"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "index",
      "title": "Search HTTP Status Codes",
      "description": "Search all available HTTP status codes by code or description",
      "mode": "view"
    }
  ],
  "categories": [
    "Developer Tools",
    "Data",
    "Documentation",
    "Web",
    "Fun"
  ],
  "engines": {
    "npm": ">=7.0.0",
    "node": ">=22.14.0"
  },
  "dependencies": {
    "@raycast/api": "^1.104.9",
    "@raycast/utils": "^2.2.2",
    "tempy": "^2.0.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.0.4",
    "@types/node": "^20.12.12",
    "eslint": "^9.22.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  },
  "preferences": [
    {
      "name": "typeOfPerson",
      "description": "Are you a cat or a dog person?",
      "type": "dropdown",
      "required": false,
      "title": "Are you a cat or a dog person?",
      "placeholder": "placeHolder",
      "default": "none",
      "data": [
        {
          "title": "None",
          "value": "none"
        },
        {
          "title": "🐈 Cat",
          "value": "cat"
        },
        {
          "title": "🐕 Dog",
          "value": "dog"
        }
      ]
    }
  ]
}
