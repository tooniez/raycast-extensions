{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "compilerOptions": {
    "allowJs": true,
    "jsx": "react-jsx",
    "lib": ["ES2021", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "strict": true
  },
  "include": ["src/**/*", "raycast-env.d.ts"],
  "exclude": ["src/__tests__", "src/__mocks__"]
}
