{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "inkdrop",
  "title": "Inkdrop",
  "description": "Control Inkdrop with Raycast",
  "icon": "inkdrop_icon.png",
  "author": "yaeda",
  "contributors": [
    "k.and"
  ],
  "categories": [
    "Productivity"
  ],
  "license": "MIT",
  "preferences": [
    {
      "name": "address",
      "type": "textfield",
      "placeholder": "127.0.0.1",
      "title": "Bind Address",
      "required": true,
      "description": "IP address of Inkdrop's client server"
    },
    {
      "name": "port",
      "type": "textfield",
      "placeholder": "19840",
      "title": "Port",
      "required": true,
      "description": "Port of Inkdrop's client server"
    },
    {
      "name": "username",
      "type": "textfield",
      "placeholder": "username",
      "title": "Username",
      "required": true,
      "description": "Username of Inkdrop's client server"
    },
    {
      "name": "password",
      "type": "password",
      "title": "Password",
      "required": true,
      "description": "Password of Inkdrop's client server"
    }
  ],
  "commands": [
    {
      "name": "search-notes",
      "title": "Search Notes",
      "subtitle": "Inkdrop",
      "description": "Search notes in Inkdrop",
      "mode": "view"
    },
    {
      "name": "create-note",
      "title": "Create Note",
      "subtitle": "Inkdrop",
      "description": "Create a new note in Inkdrop",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.6",
    "@raycast/utils": "^2.2.2"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "eslint": "^8.51.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.4.0"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  },
  "platforms": [
    "macOS"
  ]
}
