{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "google-finance",
  "title": "Google Finance",
  "description": "Track stock prices powered by Google Finance",
  "icon": "extension-icon.png",
  "author": "kyle_samani",
  "contributors": [
    "0xdhrv"
  ],
  "platforms": [
    "macOS"
  ],
  "categories": [
    "Finance"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "index",
      "title": "View Stocks",
      "description": "Look up stocks by symbol",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.11"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "ray publish"
  }
}
