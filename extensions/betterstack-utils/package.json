{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "betterstack-utils",
  "title": "BetterStack Utils",
  "description": "View your BetterStack Primary on-call schedule",
  "icon": "extension-icon.png",
  "author": "doktor500",
  "categories": [
    "Productivity"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "on-call-schedule",
      "title": "On Call Schedule",
      "description": "Shows a 3-month on-call grid for the Primary schedule",
      "mode": "view"
    },
    {
      "name": "create-incident",
      "title": "Create Incident",
      "description": "File a new BetterStack incident",
      "mode": "view"
    },
    {
      "name": "incidents",
      "title": "Incidents",
      "description": "View and manage active incidents",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "apiToken",
      "title": "API Token",
      "description": "Your BetterStack API token",
      "type": "password",
      "required": true
    },
    {
      "name": "teamId",
      "title": "Team Id",
      "description": "Your BetterStack team Id. Find it in the URL when viewing your on-call schedule: uptime.betterstack.com/team/t{id}/oncalls",
      "type": "textfield",
      "required": false
    },
    {
      "name": "requesterEmail",
      "title": "Requester Email",
      "description": "Default e-mail used when creating incidents",
      "type": "textfield",
      "required": false
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.20",
    "@tanstack/react-query": "^5.101.2",
    "clsx": "^2.1.1",
    "luxon": "^3.7.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "satori": "^0.26.0",
    "tailwind-merge": "^3.6.0",
    "ts-pattern": "^5.9.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.2.0",
    "@types/luxon": "^3.7.2",
    "@types/node": "~26.0.1",
    "@types/react": "~19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "^10.6.0",
    "prettier": "^3.9.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "vitest-tsconfig-paths": "^3.4.1"
  },
  "overrides": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "lint": "ray lint",
    "fix-lint": "ray lint --fix",
    "publish": "npx @raycast/api@latest publish",
    "ts:check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "platforms": [
    "macOS"
  ]
}
