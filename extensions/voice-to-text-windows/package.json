      "name": "transcriptionModel",
      "title": "Transcription Model",
      "description": "OpenAI model for speech-to-text. GPT-4o Transcribe is most accurate, Mini is cheapest.",
      "type": "dropdown",
      "required": false,
      "default": "gpt-4o-mini-transcribe",
      "data": [
        {
          "title": "GPT-4o Transcribe (Best quality, $0.006/min)",
          "value": "gpt-4o-transcribe"
        },
        {
          "title": "GPT-4o Mini Transcribe (Good quality, $0.003/min)",
          "value": "gpt-4o-mini-transcribe"
        },
