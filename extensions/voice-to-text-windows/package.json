{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "voice-to-text-windows",
  "title": "Voice-to-Text for Windows",
  "description": "Record speech from your microphone, transcribe it with OpenAI Whisper, and clean it up with AI",
  "icon": "extension-icon.png",
  "author": "rennesis",
  "categories": [
    "Productivity",
    "Media"
  ],
  "platforms": [
    "Windows"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "speech-to-text",
      "title": "Dictate",
      "description": "Record speech and convert to clean text",
      "mode": "view"
    },
    {
      "name": "history",
      "title": "Dictation History",
      "description": "Browse and search past dictations",
      "mode": "view"
    },
    {
      "name": "select-mode",
      "title": "Select Mode",
      "description": "Quickly switch the AI cleanup mode",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "openaiApiKey",
      "title": "OpenAI API Key",
      "description": "Your OpenAI API key for Whisper speech-to-text transcription",
      "type": "password",
      "required": true
    },
    {
      "name": "language",
      "title": "Language",
      "description": "Detect automatically, or select from 50+ available languages",
