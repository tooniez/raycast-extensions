{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "oh-shoot",
  "type": "module",
  "title": "Oh-Shoot",
  "description": "Search your oh-shoot screenshots by their OCR text and jump straight back into the oh-shoot app.",
  "icon": "command-icon.png",
  "author": "nico_pergande",
  "categories": [
    "Productivity",
    "Applications"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "search-screenshots",
      "title": "Search Screenshots",
      "description": "Search oh-shoot screenshots by the text recognised inside them (OCR).",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.99.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.0.4",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "vitest": "^2.1.9"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "lint": "ray lint",
    "fix-lint": "ray lint --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "platforms": [
    "macOS"
  ]
}
