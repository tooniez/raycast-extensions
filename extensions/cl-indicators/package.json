{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "cl-indicators",
  "title": "Chilean Indicators",
  "description": "Check Chilean financial indicators — Dólar, UF, Euro and UTM — powered by mindicador.cl",
  "icon": "icon.png",
  "author": "rodrigoherera",
  "categories": [
    "Finance"
  ],
  "license": "MIT",
  "platforms": [
    "macOS"
  ],
  "commands": [
    {
      "name": "indicators",
      "title": "View Chilean Indicators",
      "description": "Shows Chilean financial indicators: Dólar, UF, Euro, UTM",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.8",
    "@raycast/utils": "^1.15.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "typescript": "^5.2.2"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
