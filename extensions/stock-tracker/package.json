{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "stock-tracker",
  "title": "Stock Tracker",
  "description": "Shows stock market data for individual stocks or your portfolio by using Yahoo Finance.",
  "icon": "extension-icon.png",
  "author": "hmarr",
  "contributors": [
    "ericchernuka",
    "kristoffermelen",
    "vinayh"
  ],
  "categories": [
    "Finance"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "index",
      "title": "View Stocks",
      "description": "Look up stocks by symbol",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.15"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "22.19.17",
    "@types/react": "19.0.10",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "react-devtools": "6.1.1"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "ray publish"
  },
  "platforms": [
    "macOS"
  ]
}
