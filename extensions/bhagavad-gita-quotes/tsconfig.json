{
    "compilerOptions": {
        "module": "CommonJS",
        "target": "ES2021",
        "lib": [
            "ES2021",
            "DOM"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "jsx": "react-jsx"
    },
    "include": [
        "src/**/*",
        "raycast-env.d.ts"
    ]
}