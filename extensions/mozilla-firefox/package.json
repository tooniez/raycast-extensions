{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "mozilla-firefox",
  "version": "1.0.1",
  "title": "Mozilla Firefox",
  "description": "Search and open tabs from bookmarks and history in Mozilla Firefox.",
  "icon": "firefox-logo.png",
  "author": "crisboarna",
  "contributors": [
    "serhii_kravchenko",
    "Laptop765",
    "kud"
  ],
  "categories": [
    "Applications",
    "Developer Tools",
    "Productivity"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "new-tab",
      "title": "New Tab",
      "subtitle": "Mozilla Firefox",
      "description": "Open a new Mozilla Firefox tab.",
      "mode": "view",
      "preferences": [
        {
          "name": "searchEngine",
          "type": "dropdown",
          "required": false,
          "title": "Search Engine",
          "description": "Search Engine for query (default: Google).",
          "default": "Google",
          "data": [
            {
              "title": "Google",
              "value": "Google"
            },
            {
              "title": "DuckDuckGo",
              "value": "DuckDuckGo"
            },
            {
              "title": "Bing",
              "value": "Bing"
            },
            {
              "title": "Baidu",
              "value": "Baidu"
            },
            {
              "title": "Brave",
              "value": "Brave"
            }
          ]
        }
      ]
    },
    {
      "name": "search-history",
      "title": "Search History",
      "subtitle": "Mozilla Firefox",
      "description": "Search browser history.",
      "mode": "view"
    },
    {
      "name": "search-bookmarks",
      "title": "Search Bookmarks",
      "subtitle": "Mozilla Firefox",
      "description": "Search browser bookmarks.",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "browserApp",
      "title": "Firefox Application",
      "default": "Firefox",
      "description": "Which Firefox application to use",
      "type": "dropdown",
      "required": false,
      "data": [
        {
          "title": "Firefox",
          "value": "Firefox"
        },
        {
          "title": "Firefox Nightly",
          "value": "Firefox Nightly"
        },
        {
          "title": "Firefox ESR",
          "value": "Firefox ESR"
        },
        {
          "title": "Firefox Developer Edition",
          "value": "Firefox Developer Edition"
        }
      ]
    },
    {
      "name": "profileDirectorySuffix",
      "title": "Profile Directory Suffix",
      "default": "default-release",
      "description": "The Firefox profile directory suffix, the portion after the . in about://profiles",
      "type": "textfield",
      "required": false
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.12",
    "@raycast/utils": "^2.2.3"
  },
  "devDependencies": {
    "@raycast/eslint-config": "2.1.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/sql.js": "1.4.11",
    "eslint": "^10.2.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.2",
    "vitest": "4.1.4"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "ray publish",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "platforms": [
    "macOS"
  ]
}
