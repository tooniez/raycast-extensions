{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "world-cup",
  "title": "FIFA World Cup 2026™",
  "description": "See all FIFA World Cup 2026™ matches",
  "icon": "command-icon.png",
  "author": "isma",
  "contributors": [
    "djpowers",
    "pernielsentikaer"
  ],
  "categories": [
    "News",
    "Fun"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "index",
      "title": "Matches",
      "subtitle": "FIFA World Cup",
      "description": "See all matches calendar and results",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.18",
    "@raycast/utils": "^2.2.5",
    "@types/lodash.groupby": "^4.6.9",
    "cross-fetch": "^4.1.0",
    "date-fns": "^4.3.0",
    "lodash.groupby": "^4.6.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  },
  "platforms": [
    "macOS",
    "Windows"
  ]
}
