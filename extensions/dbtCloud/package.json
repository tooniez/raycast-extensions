{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "dbtcloud",
  "title": "dbt Cloud",
  "description": "Helps you get information about your dbt Cloud jobs",
  "icon": "icon.png",
  "author": "zsombor-flds",
  "contributors": [
    "xmok"
  ],
  "categories": [
    "Data",
    "Developer Tools"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "runs_index",
      "title": "Show Job Runs",
      "subtitle": "dbt Cloud",
      "description": "Show status information about dbt Cloud jobs",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.20",
    "@raycast/utils": "^2.2.7"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.0.4",
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "prepublishOnly": "echo \"\\n\\nIt seems like you are trying to publish the Raycast extension to npm.\\n\\nIf you did intend to publish it to npm, remove the \\`prepublishOnly\\` script and rerun \\`npm publish\\` again.\\nIf you wanted to publish it to the Raycast Store instead, use \\`npm run publish\\` instead.\\n\\n\" && exit 1",
    "publish": "npx @raycast/api@latest publish"
  },
  "preferences": [
    {
      "name": "dbtCloudEndpoint",
      "title": "dbt Cloud Endpoint",
      "description": "Your dbt Cloud Endpoint",
      "type": "dropdown",
      "required": true,
      "placeholder": "dbt Cloud Endpoint",
      "data": [
        {
          "title": "Production (US)",
          "value": "https://cloud.getdbt.com"
        },
        {
          "title": "Production (US) [w/ Account Prefix]",
          "value": "https://{account_prefix}.us1.dbt.com"
        },
        {
          "title": "Production (Europe)",
          "value": "https://emea.dbt.com"
        },
        {
          "title": "Production (AU)",
          "value": "https://au.dbt.com"
        }
      ]
    },
    {
      "name": "dbtCloudAcountPrefix",
      "title": "dbt Cloud Account Prefix",
      "description": "Your dbt Cloud Account Prefix",
      "type": "textfield",
      "required": false,
      "placeholder": "dbt Cloud Account Prefix"
    },
    {
      "name": "dbtCloudAPIToken",
      "title": "dbt Cloud API Token",
      "description": "Your dbt Cloud API Token",
      "type": "password",
      "required": true,
      "placeholder": "dbt Cloud API Token"
    },
    {
      "name": "dbtCloudAcountID",
      "title": "dbt Cloud Account ID",
      "description": "Your dbt Cloud Account ID",
      "type": "password",
      "required": true,
      "placeholder": "dbt Cloud Account ID"
    }
  ],
  "platforms": [
    "macOS"
  ]
}
