{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "trello",
  "title": "Trello",
  "description": "Manage Trello boards, lists, and cards from Raycast",
  "icon": "command-icon.png",
  "author": "ChrisChinchilla",
  "contributors": [
    "jimmy-b36",
    "brittanyjoiner15",
    "ajaypremshankar",
    "nahidz3"
  ],
  "platforms": [
    "macOS",
    "Windows"
  ],
  "categories": [
    "Productivity"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "searchTodos",
      "title": "Search Cards",
      "subtitle": "Trello",
      "description": "Search all cards across all your boards",
      "mode": "view"
    },
    {
      "name": "searchBoards",
      "title": "Search Boards",
      "subtitle": "Trello",
      "description": "Search all your open boards",
      "mode": "view"
    },
    {
      "name": "createTodo",
      "title": "Create a Card",
      "subtitle": "Trello",
      "description": "Create a card on a selected board/list",
      "mode": "view"
    },
    {
      "name": "index",
      "title": "Fetch all Cards",
      "subtitle": "Trello",
      "description": "Fetch all assigned cards",
      "mode": "view"
    },
    {
      "name": "listCards",
      "title": "Fetch Cards in a List",
      "subtitle": "Trello",
      "description": "View all cards in a list",
      "mode": "view"
    },
    {
      "name": "moveCard",
      "title": "Move Card",
      "subtitle": "Trello",
      "description": "Move a card to another list",
      "mode": "view"
    },
    {
      "name": "deleteCard",
      "title": "Delete Card",
      "subtitle": "Trello",
      "description": "Delete a card after confirmation",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "description": "Add your Trello Username",
      "link": "https://developer.atlassian.com/cloud/trello/guides/rest-api/api-introduction/",
      "name": "username",
      "required": true,
      "title": "Trello Username",
      "type": "textfield"
    },
    {
      "description": "Trello Access token, open this link to get one",
      "default": "https://trello.com/1/authorize?expiration=never&name=RayCastTrelloExtension&scope=read,write&response_type=token&key=13f8c59607ba6d82531d3db5f46999c1",
      "name": "token",
      "required": true,
      "title": "Personal Access Token",
      "type": "textfield"
    },
    {
      "default": "13f8c59607ba6d82531d3db5f46999c1",
      "description": "Application Trello API token, leave as is.",
      "link": "https://developer.atlassian.com/cloud/trello/guides/rest-api/api-introduction/",
      "name": "apitoken",
      "placeholder": "13f8c59607ba6d82531d3db5f46999c1",
      "required": true,
      "title": "API Token",
      "type": "textfield"
    },
    {
      "name": "closedboards",
      "title": "Include closed boards",
      "required": false,
      "type": "checkbox",
      "default": false,
      "description": "Include closed board in list",
      "label": "Include closed boards"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.102.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@types/node": "~24.3.1",
    "@types/react": "^19.1.12",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.4.0",
    "node-fetch": "^3.3.2",
    "prettier": "3.6.2",
    "typescript": "^5.9.2"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
