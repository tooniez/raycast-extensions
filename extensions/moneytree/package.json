{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "moneytree",
  "title": "Moneytree",
  "description": "View and manage your finances from Moneytree via Raycast",
  "icon": "moneytree-icon.png",
  "author": "clins1994",
  "platforms": [
    "macOS",
    "Windows"
  ],
  "categories": [
    "Data",
    "Finance"
  ],
  "license": "MIT",
  "preferences": [
    {
      "name": "email",
      "type": "password",
      "required": true,
      "title": "Email",
      "description": "Your Moneytree account email",
      "placeholder": "your.email@example.com"
    },
    {
      "name": "password",
      "type": "password",
      "required": true,
      "title": "Password",
      "description": "Your Moneytree account password",
      "placeholder": "your.password"
    },
    {
      "name": "autoReloginOnRefreshFailure",
      "type": "checkbox",
      "required": true,
      "default": true,
      "title": "Auto Re-login",
      "label": "Automatically re-login when refresh token fails",
      "description": "When enabled, the extension will automatically attempt to re-login using your stored credentials if the refresh token expires or fails"
    }
  ],
  "commands": [
    {
      "name": "list-credentials",
      "title": "List Credentials",
      "description": "Lists your credentials",
      "mode": "view"
    },
    {
      "name": "list-accounts",
      "title": "List Accounts",
      "description": "Lists your financial accounts",
      "mode": "view"
    },
    {
      "name": "list-transactions",
      "title": "List Transactions",
      "description": "Lists your latest transactions",
      "mode": "view",
      "arguments": [
        {
          "name": "query",
          "type": "text",
          "required": false,
          "placeholder": "Query"
        }
      ]
    }
  ],
  "tools": [
    {
      "name": "get-credentials",
      "title": "Get Credentials",
      "description": "Get Moneytree credentials and linked institutions, including connection status, account counts, refresh metadata, errors, and total balances."
    },
    {
      "name": "get-accounts",
      "title": "Get Accounts",
      "description": "Get Moneytree accounts with balances, currencies, types, statuses, and linked credential or institution names."
    },
    {
      "name": "search-transactions",
      "title": "Search Transactions",
      "description": "Search Moneytree transactions by date range, account, or description and return signed amounts with account context."
    }
  ],
  "ai": {
    "instructions": "Moneytree stores financial credentials/institutions, accounts, and transactions. Use get-credentials for institution connection status and grouped balances, get-accounts for account balances and account metadata, and search-transactions for spending, income, merchant, date, and account-specific questions. Treat transaction amounts as signed values: negative amounts are spending and positive amounts are income or refunds. Do not expose secrets or ask for Moneytree passwords in chat. If a question requires more rows than returned, call search-transactions with a larger maxPages or a narrower date range.",
    "evals": [
      {
        "input": "@moneytree which accounts have the highest balances?",
        "mocks": {
          "get-credentials": {
            "count": 2,
            "credentials": [
              {
                "id": 100,
                "name": "Example Bank",
                "status": "success",
                "accountCount": 1,
                "totalBalanceInBase": 120000,
                "error": null
              },
              {
                "id": 101,
                "name": "Example Card",
                "status": "success",
                "accountCount": 1,
                "totalBalanceInBase": -45000,
                "error": null
              }
            ]
          },
          "get-accounts": {
            "count": 2,
            "accounts": [
              {
                "id": 1,
                "name": "Main Checking",
                "accountType": "bank",
                "currency": "JPY",
                "currentBalance": 120000,
                "currentBalanceInBase": 120000,
                "credentialName": "Example Bank"
              },
              {
                "id": 2,
                "name": "Credit Card",
                "accountType": "credit_card",
                "currency": "JPY",
                "currentBalance": -45000,
                "currentBalanceInBase": -45000,
                "credentialName": "Example Card"
              }
            ]
          }
        },
        "expected": [
          {
            "or": [
              {
                "callsTool": "get-accounts"
              },
              {
                "callsTool": "get-credentials"
              }
            ]
          }
        ]
      },
      {
        "input": "@moneytree how much did I spend at Starbucks in May 2026?",
        "mocks": {
          "get-credentials": {
            "count": 1,
            "credentials": [
              {
                "id": 100,
                "name": "Example Bank",
                "status": "success",
                "accountCount": 1,
                "totalBalanceInBase": 120000,
                "error": null
              }
            ]
          },
          "get-accounts": {
            "count": 1,
            "accounts": [
              {
                "id": 1,
                "name": "Main Checking",
                "accountType": "bank",
                "currency": "JPY",
                "currentBalance": 120000,
                "currentBalanceInBase": 120000,
                "credentialName": "Example Bank"
              }
            ]
          },
          "search-transactions": {
            "totalCount": 2,
            "transactions": [
              {
                "id": 10,
                "date": "2026-05-04",
                "amount": -520,
                "description": "Starbucks",
                "accountName": "Main Checking"
              },
              {
                "id": 11,
                "date": "2026-05-18",
                "amount": -610,
                "description": "Starbucks",
                "accountName": "Main Checking"
              }
            ]
          }
        },
        "expected": [
          {
            "callsTool": {
              "name": "search-transactions",
              "arguments": {
                "query": {
                  "includes": "Starbucks"
                },
                "startDate": "2026-05-01",
                "endDate": "2026-05-31"
              }
            }
          }
        ]
      },
      {
        "input": "@moneytree are any of my bank connections broken?",
        "mocks": {
          "get-credentials": {
            "count": 1,
            "credentials": [
              {
                "id": 100,
                "name": "Example Bank",
                "status": "success",
                "accountCount": 1,
                "error": null
              }
            ]
          }
        },
        "expected": [
          {
            "callsTool": "get-credentials"
          }
        ]
      }
    ]
  },
  "dependencies": {
    "@raycast/api": "^1.104.12",
    "@raycast/utils": "^2.2.3"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "22.13.10",
    "@types/react": "19.2.14",
    "eslint": "^9.39.1",
    "prettier": "^3.8.2",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "prepublishOnly": "echo \"\\n\\nIt seems like you are trying to publish the Raycast extension to npm.\\n\\nIf you did intend to publish it to npm, remove the \\`prepublishOnly\\` script and rerun \\`npm publish\\` again.\\nIf you wanted to publish it to the Raycast Store instead, use \\`npm run publish\\` instead.\\n\\n\" && exit 1",
    "publish": "npx @raycast/api@latest publish"
  }
}
