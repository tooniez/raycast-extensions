{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "tabstash",
  "title": "TabStash",
  "description": "Search, browse, and capture bookmarks with TabStash",
  "icon": "icon.png",
  "author": "mkhnsn",
  "platforms": [
    "macOS"
  ],
  "categories": [
    "Web",
    "Productivity"
  ],
  "keywords": [
    "tabstash",
    "links",
    "bookmarks",
    "search",
    "capture"
  ],
  "license": "MIT",
  "access": "public",
  "commands": [
    {
      "name": "search-links",
      "title": "Search Bookmarks",
      "subtitle": "TabStash",
      "description": "Search and browse your TabStash bookmarks",
      "mode": "view",
      "keywords": [
        "tabstash",
        "search",
        "recent",
        "links",
        "bookmarks"
      ],
      "arguments": [
        {
          "name": "query",
          "placeholder": "Keyword, tag, or URL",
          "type": "text",
          "required": false
        }
      ]
    },
    {
      "name": "capture-link",
      "title": "Capture Current Tab",
      "subtitle": "TabStash",
      "description": "Save the active browser tab to TabStash",
      "mode": "no-view",
      "keywords": [
        "tabstash",
        "save",
        "capture",
        "bookmark"
      ]
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.0",
    "@raycast/utils": "^2.2.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.0",
    "typescript": "^5.9.0"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
