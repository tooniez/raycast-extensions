{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "figma-shortcuts",
  "title": "Figma Shortcuts",
  "description": "Search and copy Figma keyboard shortcuts for macOS and Windows",
  "icon": "command-icon.png",
  "author": "arturdz",
  "categories": [
    "Design Tools",
    "Productivity"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "search-shortcuts",
      "title": "Search Figma Shortcuts",
      "description": "Search Figma keyboard shortcuts and copy them to the clipboard",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.13"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  },
  "platforms": [
    "macOS",
    "Windows"
  ]
}
