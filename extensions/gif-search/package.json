    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "@giphy/js-types": "^5.1.0"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
