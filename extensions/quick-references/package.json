{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "quick-references",
  "version": "0.1.0",
  "title": "Quick References",
  "description": "Search and browse Fechin/reference cheat sheets with favorites and offline support.",
  "icon": "icon.png",
  "author": "daniel_schoeman",
  "license": "MIT",
  "categories": [
    "Developer Tools",
    "Documentation"
  ],
  "keywords": [
    "reference",
    "cheatsheet",
    "developer",
    "docs",
    "documentation"
  ],
  "commands": [
    {
      "name": "search-references",
      "title": "Search References",
      "subtitle": "Quick References",
      "description": "Search and browse Fechin/reference cheat sheets",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.88.7",
    "@raycast/utils": "^1.19.1",
    "adm-zip": "^0.5.16",
    "fuse.js": "^6.6.2",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/adm-zip": "^0.5.6",
    "@types/node": "20.8.10",
    "@types/react": "19.0.10",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  },
  "platforms": [
    "macOS"
  ]
}
