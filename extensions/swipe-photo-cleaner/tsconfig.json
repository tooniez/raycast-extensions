{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "compilerOptions": {
    "lib": ["ES2023"],
    "types": ["node"],
    "module": "commonjs",
    "target": "ES2022",
    "strict": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src", "raycast-env.d.ts"]
}
