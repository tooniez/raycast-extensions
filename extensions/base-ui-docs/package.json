{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "base-ui-docs",
  "title": "Base UI Components",
  "description": "Browse Base UI component documentation",
  "icon": "baseui-icon.png",
  "author": "lucasmotta",
  "categories": [
    "Documentation",
    "Developer Tools"
  ],
  "license": "MIT",
  "platforms": [
    "macOS"
  ],
  "commands": [
    {
      "name": "search-components",
      "title": "Search Base UI Components",
      "description": "Search and browse Base UI component documentation",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.9",
    "@raycast/utils": "^2.2.3"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "eslint": "^9.22.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "ray publish"
  }
}
