{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "yr-weather-forecast",
  "title": "Weather Forecast",
  "subtitle": "Yr",
  "description": "Weather forecast using the Norwegian Meteorological Institute's API",
  "icon": "extension-icon.png",
  "author": "kakaoduft",
  "contributors": [
    "pernielsentikaer"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kyndig/yr-wfc"
  },
  "homepage": "https://www.kynd.no",
  "bugs": {
    "url": "https://github.com/kyndig/yr-wfc/issues"
  },
  "access": "public",
  "license": "MIT",
  "keywords": [
    "weather",
    "forecast",
    "yr",
    "meteorology",
    "norway",
    "temperature",
    "precipitation",
    "wind",
    "sunrise",
    "sunset",
    "climate",
    "atmospheric"
  ],
  "categories": [
    "Productivity"
  ],
  "commands": [
    {
      "name": "yr",
      "title": "Show Weather Forecast",
      "subtitle": "Yr",
      "description": "Search and show weather",
      "mode": "view",
      "preferences": [
        {
          "name": "units",
          "label": "Units",
          "title": "Units",
          "description": "Choose metric or imperial units",
          "type": "dropdown",
          "required": false,
          "default": "metric",
          "data": [
            {
              "title": "Metric (°C, m/s, mm)",
              "value": "metric"
            },
            {
              "title": "Imperial (°F, mph, in)",
              "value": "imperial"
            }
          ]
        },
        {
          "name": "showWindDirection",
          "label": "Show Wind Direction",
          "title": "Show Wind Direction",
          "description": "Display wind direction arrows in the main view",
          "type": "checkbox",
          "required": false,
          "default": true
        },
        {
          "name": "showSunTimes",
          "label": "Show Sunrise/Sunset",
          "title": "Show Sunrise/Sunset",
          "description": "Display sunrise and sunset times in the main view",
          "type": "checkbox",
          "required": false,
          "default": true
        },
        {
          "name": "clockFormat",
          "label": "Clock Format",
          "title": "Clock Format",
          "description": "Choose 12-hour or 24-hour time format",
          "type": "dropdown",
          "required": false,
          "default": "24h",
          "data": [
            {
              "title": "24-Hour (14:30)",
              "value": "24h"
            },
            {
              "title": "12-Hour (2:30 PM)",
              "value": "12h"
            }
          ]
        },
        {
          "name": "debugMode",
          "label": "Debug Mode",
          "title": "Debug Mode",
          "description": "Show detailed console output for debugging API calls and network tests",
          "type": "checkbox",
          "required": false,
          "default": false
        }
      ]
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.102.3",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "react-error-boundary": "^6.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.0.4",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.7",
    "@types/jest": "^29.5.12",
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "eslint": "^9.22.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "build": "ray build",
    "build:ci": "ray build -e dist",
    "dev": "ray develop",
    "lint:fix": "ray lint --fix",
    "lint": "ray lint",
    "type-check": "tsc --noEmit",
    "format:check": "prettier --check src/",
    "format": "prettier --write src/",
    "check": "npm run build:ci && npm run type-check && npm run lint && TZ=Europe/Oslo npm run test:unit && npm run format:check",
    "fix": "npm run lint:fix && npm run format",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "prepublishOnly": "echo \"\\n\\nIt seems like you are trying to publish the Raycast extension to npm.\\n\\nIf you did intend to publish it to npm, remove the \\`prepublishOnly\\` script and rerun \\`npm publish\\` again.\\nIf you wanted to publish it to the Raycast Store instead, use \\`npm run publish\\` instead.\\n\\n\" && exit 1",
    "publish": "npx @raycast/api@latest publish"
  },
  "platforms": [
    "macOS"
  ]
}
