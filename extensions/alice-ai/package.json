{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "alice-ai",
  "title": "Alice AI - Your Daily AI Actions Companion",
  "description": "Alice helps with your daily tasks by providing quick access to reusable AI actions across OpenAI and Gemini models.",
  "icon": "icon.png",
  "author": "quiknull",
  "categories": [
    "Productivity",
    "Developer Tools",
    "Web",
    "Fun"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "commands",
      "title": "Select Action",
      "description": "Select available action from the list",
      "mode": "view"
    },
    {
      "name": "history",
      "title": "Show History",
      "description": "Show Results History",
      "mode": "view"
    },
    {
      "name": "create",
      "title": "Create New Action",
      "description": "Create New Action",
      "mode": "view"
    },
    {
      "name": "custom",
      "title": "Custom Action",
      "description": "Execute your custom action on the fly",
      "mode": "view",
      "arguments": [
        {
          "name": "prompt",
          "placeholder": "What's on your mind?",
          "type": "text",
          "required": true
        }
      ],
      "preferences": [
        {
          "name": "model",
          "title": "Model",
          "description": "Select Custom Action Model",
          "type": "dropdown",
          "default": "gpt-4o-mini",
          "data": [
            {
              "title": "GPT-5.4",
              "value": "gpt-5.4"
            },
            {
              "title": "GPT-5.4 Mini",
              "value": "gpt-5.4-mini"
            },
            {
              "title": "GPT-5.4 Nano",
              "value": "gpt-5.4-nano"
            },
            {
              "title": "GPT-4o",
              "value": "gpt-4o"
            },
            {
              "title": "GPT-4o Mini",
              "value": "gpt-4o-mini"
            },
            {
              "title": "Gemini 3 Flash Preview",
              "value": "gemini-3-flash-preview"
            },
            {
              "title": "Gemini 3 Pro Preview",
              "value": "gemini-3-pro-preview"
            },
            {
              "title": "Gemini 2.5 Flash",
              "value": "gemini-2.5-flash"
            },
            {
              "title": "Gemini 2.5 Flash-Lite",
              "value": "gemini-2.5-flash-lite"
            }
          ],
          "required": true
        },
        {
          "name": "temperature",
          "title": "Temperature",
          "description": "Custom Action Temperature (value between 0.0 and 1.0)",
          "type": "textfield",
          "default": "0.7",
          "required": true
        },
        {
          "name": "maxTokens",
          "title": "Max Tokens",
          "description": "Custom Action Max Tokens to be generated (set -1 for unlimited)",
          "type": "textfield",
          "default": "-1",
          "required": true
        }
      ]
    },
    {
      "name": "menubar",
      "title": "Display Actions in Menu Bar",
      "description": "Quick access your actions from the menu bar",
      "mode": "menu-bar"
    }
  ],
  "preferences": [
    {
      "name": "apikey",
      "title": "OpenAI API Key",
      "description": "Your OpenAI API Key",
      "type": "password",
      "required": false
    },
    {
      "name": "geminiApiKey",
      "title": "Gemini API Key",
      "description": "Your Gemini API Key",
      "type": "password",
      "required": false
    }
  ],
  "dependencies": {
    "@ai-sdk/google": "^1.2.22",
    "@ai-sdk/openai": "^1.3.24",
    "@raycast/api": "^1.69.0",
    "@raycast/utils": "^1.14.0",
    "@reduxjs/toolkit": "^2.2.3",
    "ai": "^4.3.16",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.6",
    "@types/node": "20.8.10",
    "@types/react": "19.0.10",
    "eslint": "^8.51.0",
    "prettier": "^3.0.3",
    "typescript": "^5.2.2"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish",
    "pull": "npx @raycast/api@latest pull-contributions"
  },
  "platforms": [
    "macOS"
  ]
}
