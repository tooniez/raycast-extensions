{
  "$schema": "https://json.schemastore.org/tsconfig",
  "include": ["src/**/*", "raycast-env.d.ts"],
  "compilerOptions": {
    "lib": ["ES2023"],
    "module": "commonjs",
    "target": "ES2023",
    "types": ["node"],
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "paths": {
      "@opencode-ai/sdk/v2": ["./node_modules/@opencode-ai/sdk/dist/v2/index.d.ts"],
      "@opencode-ai/sdk/v2/client": ["./node_modules/@opencode-ai/sdk/dist/v2/client.d.ts"]
    }
  }
}
